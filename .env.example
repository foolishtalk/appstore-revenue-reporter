# Recommended: Apple Reporter Access Token authentication
ASC_AUTH_METHOD=reporter
ASC_REPORTER_ACCESS_TOKEN=
ASC_VENDOR_NUMBER=

# Only required when the Apple account has access to multiple App Store Connect accounts
ASC_REPORTER_ACCOUNT=

# Optional: use a manually downloaded official Reporter.jar
# ASC_REPORTER_JAR=/absolute/path/to/Reporter.jar
# ASC_REPORTER_JAVA=/absolute/path/to/java

# Alternative App Store Connect API configuration kept for compatibility:
# ASC_AUTH_METHOD=api_key
# ASC_ISSUER_ID=
# ASC_KEY_ID=
# ASC_PRIVATE_KEY_BASE64=

# Full Enterprise WeChat group robot webhook URL
WECOM_WEBHOOK_URL=

# Optional overrides
# REPORT_END_DATE=2026-07-13
# REPORT_OUTPUT_DIR=output

# CNY exchange rates use the public Frankfurter v2 API; no API key is required.
